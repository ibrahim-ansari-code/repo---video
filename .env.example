# Copy to `.env` and fill in values. `.env` is gitignored.

# Required for Stage 3 (E2B cloud sandbox) when running `repovideo generate`.
# https://e2b.dev
E2B_API_KEY=

# Optional: Stage 2 anecdote / LLM (LiteLLM). Set the provider you use.
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# Or point LiteLLM at a custom gateway — see https://docs.litellm.ai/docs/

# Optional: Hugging Face (models, datasets, gated repos)
HF_TOKEN=

# Optional: force running the full E2B smoke test (install + dev server) in pytest.
# If unset, E2B tests only construct Sandbox when E2B_API_KEY is set; full start() is opt-in.
REPVIDEO_E2B_SMOKE=
